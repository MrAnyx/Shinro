{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "chrome",
			"request": "launch",
			"name": "client: brave",
			"url": "http://localhost:3000",
			"webRoot": "${workspaceFolder}/app",
			"runtimeExecutable": "C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "server: nuxt",
			"outputCapture": "std",
			"program": "${workspaceFolder}/node_modules/nuxt/bin/nuxt.mjs",
			"args": ["dev"]
		}
	],
	"compounds": [
		{
			"name": "fullstack: nuxt",
			"configurations": ["server: nuxt", "client: brave"]
		}
	]
}
